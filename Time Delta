from datetime import datetime

def time_delta(t1, t2):
    # The format string matches: Day dd Mon yyyy hh:mm:ss +xxxx
    time_format = '%a %d %b %Y %H:%M:%S %z'
    
    # Parse the strings into timezone-aware datetime objects
    dt1 = datetime.strptime(t1, time_format)
    dt2 = datetime.strptime(t2, time_format)
    
    # Calculate the absolute difference in seconds
    diff = int(abs((dt1 - dt2).total_seconds()))
    return str(diff)

# Example usage based on your input:
if __name__ == "__main__":
    t = int(input())
    for _ in range(t):
        t1 = input()
        t2 = input()
        print(time_delta(t1, t2))

