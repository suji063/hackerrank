import numpy

# Read the values for N, M, and P
n, m, p = map(int, input().split())

# Use list comprehension to read rows and convert to a NumPy array in one go
array_1 = numpy.array([input().split() for _ in range(n)], int)
array_2 = numpy.array([input().split() for _ in range(m)], int)

# Concatenate along the first dimension (axis 0)
print(numpy.concatenate((array_1, array_2), axis=0))
