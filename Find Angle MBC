import math

# Input lengths for sides AB and BC
ab = int(input())
bc = int(input())

# Calculate the angle in radians using atan(opposite/adjacent)
# Note: angle MBC = angle BCA
angle_rad = math.atan(ab / bc)

# Convert radians to degrees
angle_deg = math.degrees(angle_rad)

# Round to the nearest integer and print with the degree symbol
# Using round() with the custom formatting for the degree sign
print(f"{round(angle_deg)}{chr(176)}")

