import re
import sys

def validate_mobile_numbers():
    # Read the number of test cases
    input_data = sys.stdin.read().splitlines()
    if not input_data:
        return
    
    n = int(input_data[0])
    
    # Iterate through each string provided
    for i in range(1, n + 1):
        # ^[789] checks if it starts with 7, 8, or 9
        # \d{9}$ checks for exactly 9 more digits until the end of the string
        if re.match(r"^[789]\d{9}$", input_data[i]):
            print("YES")
        else:
            print("NO")

if __name__ == "__main__":
    validate_mobile_numbers()
