import re
import email.utils
import sys

def validate_emails():
    # Read number of inputs
    input_data = sys.stdin.read().splitlines()
    if not input_data:
        return
    n = int(input_data[0])

    # Regex breakdown:
    # ^[a-zA-Z]             -> Starts with an alphabetical character
    # [a-zA-Z0-9._-]*       -> Followed by alphanumeric, dots, underscores, or hyphens
    # @                     -> Literal @
    # [a-zA-Z]+             -> Domain: only alphabetical characters
    # \.                    -> Literal dot
    # [a-zA-Z]{1,3}$        -> Extension: alphabetical, 1 to 3 characters long
    pattern = r'^[a-zA-Z][a-zA-Z0-9._-]*@[a-zA-Z]+\.[a-zA-Z]{1,3}$'

    for i in range(1, n + 1):
        raw_input = input_data[i]
        # parseaddr returns a tuple: (Real Name, email@address.com)
        parsed_name, parsed_email = email.utils.parseaddr(raw_input)
        
        # Check if the email part matches our regex
        if re.match(pattern, parsed_email):
            # formataddr puts it back into: Name <email@address.com>
            print(email.utils.formataddr((parsed_name, parsed_email)))

if __name__ == "__main__":
    validate_emails()
