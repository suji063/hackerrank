import re

def fun(s):
    # Regex Breakdown:
    # ^[a-zA-Z0-9_-]+   -> Username: letters, digits, dashes, underscores
    # @                 -> The @ symbol
    # [a-zA-Z0-9]+      -> Website: letters and digits
    # \.                -> The dot
    # [a-zA-Z]{1,3}$    -> Extension: letters only, max length 3
    pattern = r'^[a-zA-Z0-9_-]+@[a-zA-Z0-9]+\.[a-zA-Z]{1,3}$'
    return re.match(pattern, s) is not None

def filter_mail(emails):
    return list(filter(fun, emails))
