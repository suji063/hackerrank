# Read the main set A
A = set(map(int, input().split()))

# Read the number of other sets
n = int(input())

# Assume A is a strict superset until proven otherwise
is_strict_superset = True

for _ in range(n):
    # Read each of the other sets
    other_set = set(map(int, input().split()))
    
    # Check if A is a strict superset of other_set
    # A strict superset must have at least one element that does not exist in its subset
    if not (A.issuperset(other_set) and len(A) > len(other_set)):
        is_strict_superset = False
        break

# Print the final result
print(is_strict_superset)
